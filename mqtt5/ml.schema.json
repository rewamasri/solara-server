{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SensorReading",
  "type": "object",
  "required": ["timestamp", "temperature", "humidity", "lux", "soil_pct"],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp of the reading"
    },
    "temperature": {
      "type": "number",
      "description": "Ambient air temperature from BME680",
      "units": "°C"
    },
    "humidity": {
      "type": "number",
      "description": "Relative humidity from BME680",
      "units": "% RH"
    },
    "lux": {
      "type": "number",
      "description": "Total light intensity from TSL2591",
      "units": "lux"
    },
    "soil_pct": {
      "type": "integer",
      "description": "Soil moisture percentage from ESP32",
      "minimum": 0,
      "maximum": 100,
      "units": "%"
    }
  }
}